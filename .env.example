# Notion Integration
# Duplicate the ready-made database template (no manual creation needed):
# https://marsh-rugby-3bd.notion.site/b65954654aae82a5b8110192cf9b7ce6?v=efc954654aae827985c6081721cb2b32
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# freellmapi endpoint (local or remote)
FREELLMAPI_URL=http://localhost:11434
FREELLMAPI_MODEL=llama3

# Optional: fallback OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# GitHub token for repo metadata (optional, increases rate limit)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Paths
OBSIDIAN_VAULT_PATH=vault
POOLMIND_DB_PATH=data/poolmind.db

# Behavior
AI_ENABLED=true
AI_CONFIDENCE_THRESHOLD=70
AI_DISABLE_FOR_SENSITIVE=false
NOTION_SYNC_ENABLED=true
OBSIDIAN_SYNC_ENABLED=true
LOG_LEVEL=INFO
