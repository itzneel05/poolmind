# freellmapi (AI proxy) — get the unified key from http://localhost:5173 Keys page
FREELLMAPI_URL=http://localhost:3001
FREELLMAPI_API_KEY=freellmapi-your-64-char-key-here
FREELLMAPI_MODEL=auto
AI_ENABLED=true
AI_CONFIDENCE_THRESHOLD=70

# Optional: fallback OpenAI-compatible API
OPENAI_API_KEY=

# Notion integration — see SETUP.md for full instructions
NOTION_TOKEN=
NOTION_DATABASE=
NOTION_SYNC_ENABLED=true

# Obsidian vault path — resources saved as Markdown notes
OBSIDIAN_VAULT_PATH=vault
OBSIDIAN_SYNC_ENABLED=true

# GitHub token (optional) — richer repo metadata, higher rate limits
GITHUB_TOKEN=

# Paths
POOLMIND_DB_PATH=data/poolmind.db

# Behavior
LOG_LEVEL=INFO
